# ─── Ollama (Local LLM) ───────────────────────────────────
# Base URL where your Ollama instance is running
OLLAMA_BASE_URL=http://localhost:11434

# LLM model to use for generation/chat
OLLAMA_LLM_MODEL=llama3.1:8b

# Embedding model for vector search
OLLAMA_EMBED_MODEL=nomic-embed-text


# ─── Qdrant (Vector Store) ────────────────────────────────
# URL of your Qdrant instance
QDRANT_URL=http://localhost:6333

# Collection name inside Qdrant
QDRANT_COLLECTION=documind


# ─── Reranker ─────────────────────────────────────────────
# HuggingFace model ID used for cross-encoder reranking
RERANKER_MODEL=BAAI/bge-reranker-base


# ─── SQLite (Relational Store) ────────────────────────────
# SQLAlchemy-compatible connection string
SQLITE_URL=sqlite:///./data/documind.db


# ─── Langfuse (Observability) ─────────────────────────────
# Host where your Langfuse instance is running
LANGFUSE_HOST=http://localhost:3000

# Generate these from your Langfuse project settings
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# ─── Retrieval Settings ───────────────────────────────────
# Max self-critique loops the agent can run
MAX_CRITIC_LOOPS=2

# Number of documents to retrieve from vector store
RETRIEVE_TOP_K=40

# Number of documents to keep after reranking
RERANK_TOP_N=8
